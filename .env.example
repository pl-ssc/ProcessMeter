# ==========================================
# База данных
# ==========================================
# Строка подключения к рабочей базе данных (куда сохраняются пользователи и ответы)
TARGET_DATABASE_URL=postgres://postgres:postgres@localhost:5432/processmeter

# Строка подключения к эталонной базе данных (откуда загружаются справочники процессов)
SOURCE_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/reference_db

# ==========================================
# Безопасность и Авторизация
# ==========================================
# Секретный ключ для подписи JWT токенов.
# ОБЯЗАТЕЛЬНО задайте уникальную строку в production (min 32 символа).
# Сервер не запустится в production, если оставить значение по умолчанию.
JWT_SECRET=change-me

# API ключ для защищённых административных операций
ADMIN_API_KEY=change-me

# ==========================================
# Первичный администратор
# (создаётся автоматически при первом запуске, если таблица users пуста)
# ==========================================
# Email администратора (используется как логин; должен быть валидным email)
ADMIN_USERNAME=
# Пароль администратора
ADMIN_PASSWORD=
# Полное имя администратора
ADMIN_FULL_NAME=

# ==========================================
# Настройки приложения
# ==========================================
# Публичный URL приложения — используется при формировании ссылок в email-письмах.
# Пример: https://processmeter.example.com
APP_URL=http://localhost:3001

# Название организации (отображается в заголовках и письмах)
ORG_NAME=

# Значение FTE (Full-Time Equivalent) в часах за рабочий месяц
FTE_DIVISOR=165

# ==========================================
# Настройки веб-сервера (Backend)
# ==========================================
# Порт, который слушает бэкенд
PORT=3001
# IP адрес (0.0.0.0 для Docker, 127.0.0.1 для локального запуска)
HOST=0.0.0.0
# Путь к скомпилированному фронтенду (оставьте пустым, если используете Nginx)
STATIC_DIR=/app/frontend/dist

# ==========================================
# Настройки клиента (Frontend — переменные Vite)
# ==========================================
# URL, по которому фронтенд делает запросы к API
VITE_API_URL=http://localhost:3001
# Название организации (должно совпадать с ORG_NAME)
VITE_ORG_NAME=

# ==========================================
# SMTP (настройки email)
# Можно настроить через интерфейс администратора (раздел «Настройки»).
# Переменные ниже — альтернатива для начальной инициализации.
# Все SMTP-параметры хранятся в таблице settings БД.
# ==========================================
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=noreply@example.com
# SMTP_PASSWORD=your-smtp-password
# SMTP_FROM=noreply@example.com
# SMTP_FROM_NAME=ProcessMeter

# ==========================================
# NocoDB (внешнее управление справочниками)
# ==========================================
# URL сервера NocoDB
NOCODB_URL=https://plnsi.processlabs.ru/
# API токен для доступа к NocoDB
NOCODB_API_TOKEN=kSQFoSziI3yL7Lx9PXRuGlVSDU0ZCFvzvT4ix4w5
# MCP Token (NocoDB Base - Getting Started)
NOCODB_MCP_TOKEN=Jm4kwuvu7JAqQaAkGRCnIFDKsroXvk76
