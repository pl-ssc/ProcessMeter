# ==========================================
# База данных
# ==========================================
# Строка подключения к рабочей базе данных (куда сохраняются пользователи и ответы)
TARGET_DATABASE_URL=postgres://postgres:postgres@localhost:5432/processmeter

# Строка подключения к эталонной базе данных (откуда загружаются эталонные справочники процессов)
SOURCE_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/reference_db

# ==========================================
# Безопасность и Авторизация
# ==========================================
# Секретный ключ для подписи JWT токенов (обязательно измените в production)
JWT_SECRET=change-me

# API ключ для выполнения защищенных административных скриптов
ADMIN_API_KEY=change-me

# ==========================================
# Первичный администратор 
# (создается при первой инициализации или скриптом create_admin.js)
# ==========================================
# Email администратора
ADMIN_USERNAME=
# Защищенный пароль администратора
ADMIN_PASSWORD=
# Имя администратора для отображения в интерфейсе
ADMIN_FULL_NAME=

# ==========================================
# Основные настройки приложения
# ==========================================
# Название организации (отображается в заголовках веб-интерфейса)
ORG_NAME=

# Значение FTE (Full-Time Equivalent) в часах за рабочий месяц (используется для статистики)
FTE_DIVISOR=165

# ==========================================
# Настройки веб-сервера (Backend)
# ==========================================
# Порт, который слушает бэкенд
PORT=3001
# IP адрес (используйте 0.0.0.0 для Docker или 127.0.0.1 для локального запуска)
HOST=0.0.0.0
# Путь к скомпилированному фронтенду (укажите пустую строку, если используете Nginx)
STATIC_DIR=/app/frontend/dist

# ==========================================
# Настройки клиента (Frontend - переменные Vite)
# ==========================================
# URL, по которому фронтенд делает запросы к API
VITE_API_URL=http://localhost:3001
# Название организации (должно совпадать с ORG_NAME, но с префиксом VITE_)
VITE_ORG_NAME=
